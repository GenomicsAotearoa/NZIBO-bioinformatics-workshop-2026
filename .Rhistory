brandRatingData <- parfumo_data_clean |>
filter(Rating_Count >= 19 ) |>
group_by(Brand) |>
summarize(avg_Rating = mean(Rating_Value, na.rm = TRUE),
number_Perfumes = n(),
avg_rating_count = mean(Rating_Count)) |>
filter(number_Perfumes >= 20) |>
arrange(desc(avg_Rating)) |>
